{
  "name": "default",
  "description": "Default agent",
  "tools": ["@builtin"],
  "allowedTools": ["@builtin"],
  "resources": [
    "file://.kiro/memory.md",
    "file://.kiro/KIRO.md",
    "file://.kiro/KIRO-OPS.md",
    "file://AGENTS.md",
    "file://UPSTREAM.md"
  ],
  "model": "claude-opus-4.6-1m",
  "hooks": {
    "preToolUse": [
      {
        "matcher": "execute_bash",
        "command": "bash .kiro/hooks/dcg-guard.sh",
        "description": "DCG: Block destructive commands (rm -rf, git reset --hard, force push, etc.)"
      },
      {
        "matcher": "fs_write",
        "command": "bash .kiro/hooks/fs-write-guard.sh",
        "description": "Block writes outside repo or to sensitive files (.env, secrets, credentials)"
      }
    ]
  }
}
